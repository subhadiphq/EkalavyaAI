# ================================================================
# EkalavyaAI — Environment Variables
# Copy this file to .env and fill in your values
# ================================================================

# ── App ─────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000"]

# ── AI Model APIs (Get from each provider's console) ────────────
# OpenRouter: https://openrouter.ai/keys  (Claude, GPT-4o, Gemini via one key)
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Groq: https://console.groq.com (Free - Llama 3.1 70B for Memory Agent)
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# Google AI Studio: https://aistudio.google.com (Gemini 1.5 Pro for Syllabus Agent)
GOOGLE_AI_STUDIO_API_KEY=AIzaSy_YOUR_KEY_HERE

# Cohere: https://dashboard.cohere.com (Reranking)
COHERE_API_KEY=YOUR_COHERE_KEY_HERE

# ── Databases ────────────────────────────────────────────────────
# PostgreSQL (local dev uses docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://ekalavya:ekalavya_dev_pass@localhost:5432/ekalavya

# Redis
REDIS_URL=redis://localhost:6379/0

# Pinecone: https://app.pinecone.io
PINECONE_API_KEY=YOUR_PINECONE_KEY_HERE
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=ekalavya-knowledge
PINECONE_MEMORY_INDEX=ekalavya-memory

# Neo4j (optional - for knowledge graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ElasticSearch (local dev uses docker-compose)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=ekalavya-chunks

# ── Auth ─────────────────────────────────────────────────────────
# Supabase: https://supabase.com (for Google OAuth)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=eyJhbGc...YOUR_ANON_KEY

# JWT (generate a random 32+ character secret)
JWT_SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── Storage ──────────────────────────────────────────────────────
# AWS S3 (for PDF/DOCX storage)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_S3_BUCKET=ekalavya-notes
AWS_REGION=ap-south-1

# Cloudflare R2 (cheaper alternative to S3 - optional)
# USE_R2=true
# CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT.r2.cloudflarestorage.com
# CLOUDFLARE_R2_ACCESS_KEY=YOUR_R2_ACCESS_KEY
# CLOUDFLARE_R2_SECRET_KEY=YOUR_R2_SECRET_KEY

# ── Payment (Cashfree) ───────────────────────────────────────────
# Get from: https://merchant.cashfree.com
CASHFREE_APP_ID=YOUR_CASHFREE_APP_ID
CASHFREE_SECRET_KEY=YOUR_CASHFREE_SECRET
CASHFREE_ENV=TEST

# ── Email (Resend) ───────────────────────────────────────────────
# Get from: https://resend.com
RESEND_API_KEY=re_YOUR_RESEND_KEY
FROM_EMAIL=noreply@ekalavya.ai
FROM_NAME=EkalavyaAI

# ── Monitoring (Optional) ────────────────────────────────────────
# LangSmith: https://smith.langchain.com
LANGSMITH_API_KEY=ls__YOUR_KEY
LANGSMITH_PROJECT=ekalavya-ai

# Sentry: https://sentry.io
SENTRY_DSN=https://YOUR_KEY@sentry.io/PROJECT_ID

# ── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
